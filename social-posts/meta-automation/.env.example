# Copy this file to .env and fill values from Meta.
# Do not commit .env with real tokens.

META_GRAPH_VERSION=v21.0
INSTAGRAM_GRAPH_VERSION=
THREADS_GRAPH_VERSION=

# Facebook Page
FACEBOOK_PAGE_ID=962902993572061
FACEBOOK_PAGE_ACCESS_TOKEN=

# Instagram Business / Creator account connected to the Facebook Page
INSTAGRAM_USER_ID=
INSTAGRAM_ACCESS_TOKEN=

# Threads account, optional
THREADS_USER_ID=
THREADS_ACCESS_TOKEN=

# Telegram channel/chat, optional
# Create a bot via @BotFather, add it as admin to the channel, and use @channelusername or numeric chat id.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# TikTok Content Posting API, optional
# MEDIA_UPLOAD sends the post to TikTok inbox/drafts for final confirmation in the app.
# DIRECT_POST posts directly, but requires TikTok Direct Post approval and video.publish authorization.
TIKTOK_ACCESS_TOKEN=
TIKTOK_POST_MODE=MEDIA_UPLOAD
TIKTOK_PRIVACY_LEVEL=PUBLIC_TO_EVERYONE
TIKTOK_DISABLE_COMMENT=false
TIKTOK_AUTO_ADD_MUSIC=true

# Safety
DRY_RUN=true
